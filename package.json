{
  "name": "trips",
  "version": "1.0.0",
  "private": true,
  "description": "Trip itineraries as a planning doc + GitHub Pages map app, kept in sync. See CLAUDE.md.",
  "scripts": {
    "sync": "node assets/sync.js",
    "sync:italy": "node assets/sync.js italy",
    "sync:westfjords": "node assets/sync.js westfjords",
    "routes:italy": "python3 trips/italy/routes.py",
    "routes:westfjords": "python3 trips/westfjords/routes.py",
    "serve": "python3 -m http.server 8000",
    "start": "python3 -m http.server 8000"
  },
  "engines": {
    "node": ">=18"
  }
}
